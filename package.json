{
  "name": "sds",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "app:dev": "vite",
    "app:build": "tsc && vite build",
    "app:lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "app:preview": "vite preview",
    "concept:1": "vite concepts/concept-1 --config vite.config.ts --port 8001",
    "concept:1:build": "vite build concepts/concept-1 --config vite.config.ts",
    "concept:1:preview": "vite preview concepts/concept-1 --config vite.config.ts --port 8001",
    "concept:2": "vite concepts/concept-2 --config vite.config.ts --port 8002",
    "concept:2:build": "vite build concepts/concept-2 --config vite.config.ts",
    "concept:2:preview": "vite preview concepts/concept-2 --config vite.config.ts --port 8002",
    "concept:3": "vite concepts/concept-3 --config vite.config.ts --port 8003",
    "concept:3:build": "vite build concepts/concept-3 --config vite.config.ts",
    "concept:3:preview": "vite preview concepts/concept-3 --config vite.config.ts --port 8003",
    "concept:4": "vite concepts/concept-4 --config vite.config.ts --port 8004",
    "concept:4:build": "vite build concepts/concept-4 --config vite.config.ts",
    "concept:4:preview": "vite preview concepts/concept-4 --config vite.config.ts --port 8004",
    "concept:5": "vite concepts/concept-5 --config vite.config.ts --port 8005",
    "concept:5:build": "vite build concepts/concept-5 --config vite.config.ts",
    "concept:5:preview": "vite preview concepts/concept-5 --config vite.config.ts --port 8005",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build --output-dir dist/storybook",
    "build": "npm run app:build; npm run storybook:build",
    "script:dev-resources": "cd scripts/dev-resources; node --env-file=../../.env app.mjs; cd -;",
    "script:icons": "cd scripts/icons; node --env-file=../../.env app.mjs --skip-rest-api; cd -;",
    "script:icons:rest": "cd scripts/icons; node --env-file=../../.env app.mjs; cd -;",
    "script:tokens": "cd scripts/tokens; node --env-file=../../.env app.mjs --skip-rest-api; cd -;",
    "script:tokens:rest": "cd scripts/tokens; node --env-file=../../.env app.mjs; cd -;"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.10",
    "@react-types/shared": "^3.23.0",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-links": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/manager-api": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@storybook/theming": "^8.6.12",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "clsx": "^2.1.1",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-storybook": "^0.8.0",
    "prettier-plugin-organize-imports": "^3.2.4",
    "react": "^18.2.0",
    "react-aria-components": "^1.10.1",
    "react-dom": "^18.2.0",
    "storybook": "^8.6.12",
    "typescript": "^5.0.2",
    "vite": "^6.3.5"
  }
}
